// ---------- 点击爆裂粒子 ----------
.kira-click-burst {
	position: fixed;
	z-index: 99999;
	pointer-events: none;
	user-select: none;
	line-height: 1;
	will-change: transform, opacity;
}

// ======================================================
// 第一梯队美化：卡片竖条 / 标题画线 / 图片淡入 / 侧栏标题色块
// ======================================================

// ---------- 1. 文章卡片左侧渐变竖条（hover 滑出） ----------
.kira-content .kira-main-content .kira-posts .kira-post {
	position: relative;

	&::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 4px;
		height: 100%;
		background: linear-gradient(180deg, $color1, $color2);
		border-radius: 16px 0 0 16px;
		transform: scaleY(0);
		transform-origin: top;
		transition: transform 0.32s ease;
		z-index: 3;
	}

	&:hover::before {
		transform: scaleY(1);
	}
}

// ---------- 2. 卡片标题悬停渐变下划线（从左画到右） ----------
.kira-content .kira-main-content .kira-posts .kira-post {
	.kira-post-cover + h1,
	> a h1 {
		position: relative;
		display: inline-block;
		background-image: linear-gradient(90deg, $color1, $color2);
		background-repeat: no-repeat;
		background-position: 0 100%;
		background-size: 0% 2px;
		transition: background-size 0.4s ease, color 0.3s ease;
		padding-bottom: 2px;
	}

	&:hover h1 {
		background-size: 100% 2px;
		color: $color1;
	}
}

// ---------- 3. 正文图片：圆角阴影 + 加载淡入 + hover 微放大 ----------
.kira-main-content article img:not(.kira-post-cover-image) {
	border-radius: 12px;
	box-shadow: 0 6px 20px rgba(116, 142, 166, 0.18);
	transition: transform 0.4s ease, box-shadow 0.4s ease, opacity 0.5s ease;

	&:hover {
		transform: translateY(-3px) scale(1.012);
		box-shadow: 0 12px 30px rgba($color1, 0.25);
	}
}

// 封面图保持原样（不被正文图样式影响）
.kira-main-content .kira-post-cover img {
	border-radius: 0;
	box-shadow: none;
}

// ---------- 4. 侧栏小工具标题左侧渐变色块 ----------
.kira-sidebar .kira-widget-wrap .kira-widget-title {
	position: relative;
	padding-left: 28px !important;

	&::before {
		content: '';
		position: absolute;
		left: 18px;
		top: 50%;
		transform: translateY(-50%);
		width: 4px;
		height: 1em;
		border-radius: 4px;
		background: linear-gradient(180deg, $color1, $color2);
	}
}




